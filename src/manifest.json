{
  "manifest_version": 3,
  "name": "古风竖排图片|支持诗词短文",
  "version": "1.0",
  "description": "点击插件图标进入选择模式，点击div提取文字并在A5浮层中显示",
  "permissions": ["activeTab", "scripting", "tabs", "contextMenus", "storage"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_title": "选择元素提取文字"
  },
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [{
    "resources": ["libs/html2canvas.min.js"],
    "resources": ["image/*"],
    "matches": ["<all_urls>"]
  }]
}